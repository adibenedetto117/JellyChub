#:kivy 2.0.0

<MusicScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(8)
        
        MDTopAppBar:
            title: "Music"
            left_action_items: [["menu", lambda x: app.root.ids.nav_drawer.set_state("open")]]
            right_action_items: [["refresh", lambda x: root.refresh()]]
            elevation: 4
        
        ScrollView:
            do_scroll_x: False
            
            MDList:
                spacing: dp(16)
                padding: dp(8)
                
                # Libraries section
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    padding: dp(8)
                    spacing: dp(8)
                    
                    MDLabel:
                        text: "Libraries"
                        font_style: "H6"
                        adaptive_height: True
                    
                    MDList:
                        id: libraries_list
                        spacing: dp(4)
                        adaptive_height: True
                        no_selection: True
                
                MDDivider:
                
                # Recent albums section
                MDBoxLayout:
                    orientation: 'vertical'
                    adaptive_height: True
                    padding: dp(8)
                    spacing: dp(8)
                    
                    MDLabel:
                        text: "Recent Albums"
                        font_style: "H6"
                        adaptive_height: True
                    
                    MDGridLayout:
                        id: recent_albums_grid
                        cols: 2
                        spacing: dp(8)
                        adaptive_height: True
                        size_hint_y: None
                        height: self.minimum_height
                    
                    MDSpinner:
                        size_hint: None, None
                        size: dp(46), dp(46)
                        pos_hint: {'center_x': .5}
                        active: root.loading