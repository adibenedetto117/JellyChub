#:kivy 2.0.0

<ArtistCard>:
    orientation: 'vertical'
    padding: 0
    md_bg_color: app.theme_cls.bg_normal
    
    BoxLayout:
        orientation: 'vertical'
        padding: 0
        spacing: 0
        
        # Artist image container
        BoxLayout:
            size_hint_y: 0.8
            
            FitImage:
                source: root.artist_image
                radius: root.radius
            
            # Loading spinner overlay
            MDSpinner:
                size_hint: None, None
                size: dp(30), dp(30)
                pos_hint: {'center_x': .5, 'center_y': .5}
                active: root.loading_image
        
        # Artist name container
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.2
            padding: dp(8), dp(4)
            
            MDLabel:
                text: root.artist_name
                font_style: 'Body1'
                bold: True
                halign: 'center'
                shorten: True
                shorten_from: 'right'